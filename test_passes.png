// ============================================================
// UVM Testbench — N-Tap Parameterized FIR Filter
// EDA Playground settings:
//   Simulator : Aldec Rivera-PRO
//   UVM       : UVM 1.2
//   Compile   : -timescale 1ns/1ps
//   Tick "Open EPWave after run"
// Paste into "testbench.sv"
// ============================================================

`include "uvm_macros.svh"
import uvm_pkg::*;

// ============================================================
// 1. TRANSACTION
// ============================================================
class fir_transaction extends uvm_sequence_item;
  `uvm_object_utils(fir_transaction)

  rand logic signed [15:0] data_in;
  logic signed [31:0]      data_out;
  logic                    out_valid;

  constraint c_input_range {
    data_in inside {[-32768:32767]};
  }

  function new(string name = "fir_transaction");
    super.new(name);
  endfunction

  function string convert2string();
    return $sformatf("data_in=%0d | data_out=%0d | out_valid=%0b",
                      data_in, data_out, out_valid);
  endfunction
endclass


// ============================================================
// 2. SEQUENCES
// ============================================================

// (a) Directed — fixed ramp inputs for sanity check
class fir_directed_seq extends uvm_sequence #(fir_transaction);
  `uvm_object_utils(fir_directed_seq)

  function new(string name = "fir_directed_seq");
    super.new(name);
  endfunction

  task body();
    fir_transaction tx;
    repeat(16) begin
      tx = fir_transaction::type_id::create("tx");
      start_item(tx);
      tx.data_in = $urandom_range(0, 15) * 100;
      finish_item(tx);
    end
  endtask
endclass

// (b) Corner — one value per coverage bin, guarantees 100% cp_input coverage
class fir_corner_seq extends uvm_sequence #(fir_transaction);
  `uvm_object_utils(fir_corner_seq)

  function new(string name = "fir_corner_seq");
    super.new(name);
  endfunction

  task body();
    fir_transaction tx;
    // Explicitly hits every cp_input bin
    automatic logic signed [15:0] corners [5] = '{
      -30000,  // neg_large  : [-32768 : -16384]
      -500,    // neg_small  : [-16383 :     -1]
      0,       // zero       : {0}
      500,     // pos_small  : [    1  :  16383]
      30000    // pos_large  : [16384  :  32767]
    };
    foreach (corners[i]) begin
      tx = fir_transaction::type_id::create("tx");
      start_item(tx);
      tx.data_in = corners[i];
      finish_item(tx);
    end
  endtask
endclass

// (c) Random — 1000 constrained-random transactions for thorough coverage
class fir_random_seq extends uvm_sequence #(fir_transaction);
  `uvm_object_utils(fir_random_seq)

  int unsigned num_transactions = 1000;

  function new(string name = "fir_random_seq");
    super.new(name);
  endfunction

  task body();
    fir_transaction tx;
    repeat(num_transactions) begin
      tx = fir_transaction::type_id::create("tx");
      start_item(tx);
      assert(tx.randomize()) else
        `uvm_fatal("SEQ", "Randomization failed")
      finish_item(tx);
    end
  endtask
endclass


// ============================================================
// 3. DRIVER
// ============================================================
class fir_driver extends uvm_driver #(fir_transaction);
  `uvm_component_utils(fir_driver)

  virtual fir_if vif;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db #(virtual fir_if)::get(this, "", "vif", vif))
      `uvm_fatal("DRV", "Could not get virtual interface")
  endfunction

  task run_phase(uvm_phase phase);
    fir_transaction tx;
    vif.data_in    <= '0;
    vif.data_valid <= 1'b0;
    @(posedge vif.rst_n);
    @(posedge vif.clk);

    forever begin
      seq_item_port.get_next_item(tx);
      @(posedge vif.clk);
      vif.data_in    <= tx.data_in;
      vif.data_valid <= 1'b1;
      @(posedge vif.clk);
      vif.data_valid <= 1'b0;
      seq_item_port.item_done();
    end
  endtask
endclass


// ============================================================
// 4. MONITOR
// Captures on out_valid — aligned with fixed DUT
// ============================================================
class fir_monitor extends uvm_monitor;
  `uvm_component_utils(fir_monitor)

  virtual fir_if vif;
  uvm_analysis_port #(fir_transaction) ap;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    if (!uvm_config_db #(virtual fir_if)::get(this, "", "vif", vif))
      `uvm_fatal("MON", "Could not get virtual interface")
  endfunction

  task run_phase(uvm_phase phase);
    fir_transaction tx;
    forever begin
      @(posedge vif.clk);
      if (vif.out_valid) begin
        tx           = fir_transaction::type_id::create("tx");
        tx.data_in   = vif.data_in;
        tx.data_out  = vif.data_out;
        tx.out_valid = vif.out_valid;
        ap.write(tx);
      end
    end
  endtask
endclass


// ============================================================
// 5. SCOREBOARD
// Inline reference model — mirrors DUT blocking assignment fix
// ============================================================
class fir_scoreboard extends uvm_scoreboard;
  `uvm_component_utils(fir_scoreboard)

  uvm_analysis_imp #(fir_transaction, fir_scoreboard) analysis_export;

  localparam int N_TAPS = 8;
  logic signed [15:0] ref_shift_reg [0:N_TAPS-1];
  logic signed [15:0] COEFFS [0:N_TAPS-1] = '{
    16'sd256,  16'sd512,  16'sd1024, 16'sd2048,
    16'sd2048, 16'sd1024, 16'sd512,  16'sd256
  };

  int pass_count = 0;
  int fail_count = 0;

  function new(string name, uvm_component parent);
    super.new(name, parent);
    foreach (ref_shift_reg[i]) ref_shift_reg[i] = '0;
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    analysis_export = new("analysis_export", this);
  endfunction

  function void write(fir_transaction tx);
    logic signed [31:0] expected;
    int i;

    // Mirror DUT: shift first (blocking), then MAC
    for (i = N_TAPS-1; i > 0; i--)
      ref_shift_reg[i] = ref_shift_reg[i-1];
    ref_shift_reg[0] = tx.data_in;

    // Compute expected output
    expected = '0;
    for (i = 0; i < N_TAPS; i++)
      expected += ref_shift_reg[i] * COEFFS[i];

    // Compare
    if (tx.data_out === expected) begin
      pass_count++;
      `uvm_info("SCB", $sformatf("PASS | in=%0d | got=%0d | exp=%0d",
                 tx.data_in, tx.data_out, expected), UVM_MEDIUM)
    end else begin
      fail_count++;
      `uvm_error("SCB", $sformatf("FAIL | in=%0d | got=%0d | exp=%0d",
                  tx.data_in, tx.data_out, expected))
    end
  endfunction

  function void report_phase(uvm_phase phase);
    `uvm_info("SCB", $sformatf(
      "\n==========================================\n  SCOREBOARD RESULTS\n  PASS: %0d | FAIL: %0d\n==========================================",
      pass_count, fail_count), UVM_NONE)
  endfunction
endclass


// ============================================================
// 6. FUNCTIONAL COVERAGE
// ============================================================
class fir_coverage extends uvm_subscriber #(fir_transaction);
  `uvm_component_utils(fir_coverage)

  fir_transaction tx;

  covergroup fir_cg;
    cp_input: coverpoint tx.data_in {
      bins neg_large  = {[-32768:-16384]};
      bins neg_small  = {[-16383:   -1]};
      bins zero       = {0};
      bins pos_small  = {[    1: 16383]};
      bins pos_large  = {[16384: 32767]};
    }
    cp_out_valid: coverpoint tx.out_valid {
      bins valid   = {1};
      bins invalid = {0};
    }
    cx_input_x_valid: cross cp_input, cp_out_valid;
  endgroup

  function new(string name, uvm_component parent);
    super.new(name, parent);
    fir_cg = new();
  endfunction

  function void write(fir_transaction t);
    tx = t;
    fir_cg.sample();
  endfunction

  function void report_phase(uvm_phase phase);
    `uvm_info("COV", $sformatf(
      "Functional Coverage = %.2f%%", fir_cg.get_coverage()), UVM_NONE)
  endfunction
endclass


// ============================================================
// 7. AGENT
// ============================================================
class fir_agent extends uvm_agent;
  `uvm_component_utils(fir_agent)

  fir_driver    drv;
  fir_monitor   mon;
  uvm_sequencer #(fir_transaction) seqr;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    drv  = fir_driver::type_id::create("drv", this);
    mon  = fir_monitor::type_id::create("mon", this);
    seqr = uvm_sequencer #(fir_transaction)::type_id::create("seqr", this);
  endfunction

  function void connect_phase(uvm_phase phase);
    drv.seq_item_port.connect(seqr.seq_item_export);
  endfunction
endclass


// ============================================================
// 8. ENVIRONMENT
// ============================================================
class fir_env extends uvm_env;
  `uvm_component_utils(fir_env)

  fir_agent      agent;
  fir_scoreboard scb;
  fir_coverage   cov;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    agent = fir_agent::type_id::create("agent", this);
    scb   = fir_scoreboard::type_id::create("scb", this);
    cov   = fir_coverage::type_id::create("cov", this);
  endfunction

  function void connect_phase(uvm_phase phase);
    agent.mon.ap.connect(scb.analysis_export);
    agent.mon.ap.connect(cov.analysis_export);
  endfunction
endclass


// ============================================================
// 9. TESTS
// ============================================================

// Directed test — sanity check with known values
class fir_directed_test extends uvm_test;
  `uvm_component_utils(fir_directed_test)

  fir_env env;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    env = fir_env::type_id::create("env", this);
  endfunction

  task run_phase(uvm_phase phase);
    fir_directed_seq seq;
    phase.raise_objection(this);
    seq = fir_directed_seq::type_id::create("seq");
    seq.start(env.agent.seqr);
    #100;
    phase.drop_objection(this);
  endtask
endclass

// Coverage-driven test:
// Step 1 — corner sequence hits every bin deterministically
// Step 2 — 1000 random transactions for thorough verification
class fir_coverage_test extends uvm_test;
  `uvm_component_utils(fir_coverage_test)

  fir_env env;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    env = fir_env::type_id::create("env", this);
  endfunction

  task run_phase(uvm_phase phase);
    fir_corner_seq corners;
    fir_random_seq rand_seq;
    phase.raise_objection(this);

    // Step 1 — guarantee all coverage bins hit
    `uvm_info("TEST", "Running corner sequence to hit all coverage bins...", UVM_NONE)
    corners = fir_corner_seq::type_id::create("corners");
    corners.start(env.agent.seqr);

    // Step 2 — 1000 random transactions
    `uvm_info("TEST", "Running 1000 random transactions...", UVM_NONE)
    rand_seq = fir_random_seq::type_id::create("rand_seq");
    rand_seq.num_transactions = 1000;
    rand_seq.start(env.agent.seqr);

    #100;
    phase.drop_objection(this);
  endtask
endclass


// ============================================================
// 10. TOP MODULE
// ============================================================
module tb_top;
  import uvm_pkg::*;
  `include "uvm_macros.svh"

  logic clk;
  logic rst_n;

  initial clk = 0;
  always #5 clk = ~clk;

  initial begin
    rst_n = 1'b0;
    repeat(4) @(posedge clk);
    rst_n = 1'b1;
  end

  fir_if dut_if (.clk(clk), .rst_n(rst_n));

  fir_filter #(
    .N_TAPS(8),
    .DATA_W(16),
    .COEF_W(16),
    .ACC_W (32)
  ) dut (
    .clk        (clk),
    .rst_n      (rst_n),
    .data_in    (dut_if.data_in),
    .data_valid (dut_if.data_valid),
    .data_out   (dut_if.data_out),
    .out_valid  (dut_if.out_valid)
  );

  initial begin
    uvm_config_db #(virtual fir_if)::set(null, "uvm_test_top.*", "vif", dut_if);
    // Tests available:
    //   "fir_directed_test"  — 16 directed transactions (sanity check)
    //   "fir_coverage_test"  — 5 corner + 1000 random (full coverage run)
    run_test("fir_coverage_test");
  end

  // Rivera-PRO compatible waveform dump
  initial begin
    $dumpfile("dump.vcd");
    $dumpvars(0, tb_top);
    $dumpon;
  end

endmodule
